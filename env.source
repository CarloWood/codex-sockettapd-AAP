if [[ -z "${PLANROOT:-}" ]]; then
  echo "ERROR: PLANROOT is not set." >&2
  return 1 2>/dev/null || exit 1
fi

if [[ ! -f "$PLANROOT/agents-common/bash/aap.bash" ]]; then
  echo "ERROR: $PLANROOT/agents-common/bash/aap.bash does not exist." >&2
  return 1 2>/dev/null || exit 1
fi

source "$PLANROOT/agents-common/bash/aap.bash"

